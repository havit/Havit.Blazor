@namespace Havit.Blazor.Components.Web.Bootstrap.Internal
@using Microsoft.Extensions.Localization

<button type="button"
		class="@CssClassHelper.Combine("hx-sidebar-toggler", Collapsed ? "collapsed" : null)"
		aria-controls="@AriaControlsId"
		aria-expanded="@(!Collapsed ? "true" : "false")"
		aria-label="@(Collapsed ? Localizer["Expand"] : Localizer["Collapse"])"
		@onclick="InvokeOnClickAsync"
		@onclick:stopPropagation="true">

	@if (TogglerTemplate is null)
	{
		<HxTooltip Placement="TooltipPlacement.Right" Text="@(Collapsed ? Localizer["Expand"] : Localizer["Collapse"])">
			<div class="hx-sidebar-toggler-inner">
				<div class="hx-sidebar-toggler-arrow"></div>
				<div class="hx-sidebar-toggler-arrow"></div>
			</div>
		</HxTooltip>
	}
	else
	{
		@TogglerTemplate(new() { SidebarCollapsed = Collapsed })
	}
</button>

@code
{
	[Inject] protected IStringLocalizer<HxSidebar> Localizer { get; set; }

	/// <summary>
	/// Indicates whether the sidebar is collapsed (drives the toggler direction, tooltip and aria attributes).
	/// </summary>
	[Parameter] public bool Collapsed { get; set; }

	/// <summary>
	/// The ID of the sidebar element the toggler controls.
	/// </summary>
	[Parameter] public string AriaControlsId { get; set; }

	/// <summary>
	/// Custom toggler visual to be rendered instead of the default bar/arrow.
	/// </summary>
	[Parameter] public RenderFragment<SidebarTogglerTemplateContext> TogglerTemplate { get; set; }

	/// <summary>
	/// Raised on toggler click.
	/// </summary>
	[Parameter] public EventCallback OnClick { get; set; }

	private Task InvokeOnClickAsync() => OnClick.InvokeAsync();
}
