@namespace Havit.Blazor.Components.Web.Bootstrap

<CascadingValue Value="@this" IsFixed="true">
	@{
		StartCollectingTabs();
	}
	@ChildContent
	<Havit.Blazor.Components.Web.Internal.HxDeferInternal>
		@{
			FinishCollectingTabs();
		}

		@if (Variant == TabPanelVariant.Standard)
		{
			@if (Orientation == NavOrientation.Vertical)
			{
				<div class="d-flex align-items-start">
					@_renderTabsNavigation
					@_renderTabsContent
				</div>
			}
			else
			{
				@_renderTabsNavigation
				@_renderTabsContent
			}
		}

		@if (Variant == TabPanelVariant.Card)
		{
			<HxCard Settings="CardSettings">
				<HeaderTemplate>
					@_renderTabsNavigation
				</HeaderTemplate>
				<BodyTemplate>
					@_renderTabsContent
				</BodyTemplate>
			</HxCard>
		}
	</Havit.Blazor.Components.Web.Internal.HxDeferInternal>
</CascadingValue>

@code {
	private void RenderTabsNavigation(RenderTreeBuilder __builder)
	{
		<HxNav CssClass="@CssClassHelper.Combine("hx-tab-panel", GetNavCssClassInCardMode(), GetNavCssClassForOrientation(), CssClass)"
		       Variant="NavVariant"
		       Orientation="GetNavOrientation()"
		       role="tablist"
		       aria-orientation="@GetNavAriaOrientation()">
			@foreach (HxTab tab in _tabsListOrdered)
			{
				@if (tab.Visible)
				{
					bool isActive = IsActive(tab);
					bool isEnabled = CascadeEnabledComponent.EnabledEffective(tab);
					string ariaControls = (RenderMode == TabPanelRenderMode.AllTabs || isActive) ? tab.Id : null;

					if (TabHeadersAsButtons)
					{
						<button @key="@tab.Id"
						        type="button"
						        class="@CssClassHelper.Combine("nav-link", (isActive ? "active" : null), (isEnabled ? null : "disabled"), tab.TitleCssClass)"
						        @onclick="async () => await HandleTabClick(tab)"
						        disabled="@(!isEnabled)"
						        role="tab"
						        id="@(tab.Id + "-header")"
						        aria-controls="@ariaControls"
						        aria-describedby="@ariaControls"
						        aria-selected="@(isActive ? "true" : "false")"
						        tabindex="@(isActive ? "0" : "-1")">
							@tab.Title
							@tab.TitleTemplate
						</button>
					}
					else
					{
						<HxNavLink @key="@tab.Id"
						           OnClick="async () => await HandleTabClick(tab)"
						           CssClass="@CssClassHelper.Combine((isActive ? "active" : null), tab.TitleCssClass)"
						           Enabled="isEnabled"
						           role="tab"
						           id="@(tab.Id + "-header")"
						           aria-controls="@ariaControls"
						           aria-describedby="@ariaControls"
						           aria-selected="@(isActive ? "true" : "false")"
						           tabindex="@(isActive ? "0" : "-1")">
							@tab.Title
							@tab.TitleTemplate
						</HxNavLink>
					}
				}
			}
		</HxNav>
	}

	private void RenderTabsContent(RenderTreeBuilder __builder)
	{
		<div class="tab-content">
			@foreach (HxTab tab in _tabsListOrdered)
			{
				@if (tab.Visible)
				{
					if ((RenderMode == TabPanelRenderMode.AllTabs)
					|| ((RenderMode == TabPanelRenderMode.ActiveTabOnly) && IsActive(tab)))
					{
                        <div @key="@tab.Id" id="@tab.Id" role="tabpanel" aria-labelledby="@(tab.Id + "-header")" tabindex="0"  class="@CssClassHelper.Combine("tab-pane", (Fade ? "fade" : null), (IsActive(tab) ? (Fade ? "show active" : "active") : null), tab.ContentCssClass)">
                            @tab.Content
						</div>
					}
				}
			}
		</div>
	}
}
