@namespace Havit.Blazor.Components.Web.Bootstrap
<HxDialog @ref="_dialog"
         Title="@Title"
         ShowCloseButton="ShowCloseButton"
         Settings="DialogSettingsEffective"
         OnClosed="HandleDialogClosed"
         HeaderTemplate="HeaderTemplate"
         @attributes="this.AdditionalAttributes">
    <BodyTemplate>
        @Text
        @BodyTemplate
    </BodyTemplate>
    <FooterTemplate>
        @foreach (var button in GetButtonsToRender())
        {
            <HxButton @key="@button" Text="@button.Text"
                  OnClick="@(() => HandleButtonClick(button.Id))"
                  Settings="@((button.IsPrimary ?? false) ? PrimaryButtonSettingsEffective : SecondaryButtonSettingsEffective)"
                  tabindex="0" />
        }
    </FooterTemplate>
</HxDialog>