@namespace Havit.Blazor.Components.Web.Bootstrap

<div class="progress" role="progressbar" style="width: @($"{GetNormalizedValue()}%;") height: @($"{ProgressBarContainer.Height}px;")" aria-label="@Label" aria-valuenow="@Value" aria-valuemin="@MinValueEffective" aria-valuemax="@MaxValueEffective">
    <div class="@CssClassHelper.Combine("progress-bar", GetStripedCssClass(), ThemeColorExtensions.ToBackgroundColorCss(Color ?? ThemeColor.None), CssClass)">@Label @ChildContent</div>
</div>
