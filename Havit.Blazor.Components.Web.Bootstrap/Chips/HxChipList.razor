@namespace Havit.Blazor.Components.Web.Bootstrap
<div class="@CssClassHelper.Combine("hx-chip-list", CssClassEffective)">
	@if (Chips != null)
	{
		foreach (ChipItem chipItem in Chips)
		{
			<span @key="@chipItem" class="@CssClassHelper.Combine("chip", ColorEffective.ToThemeCss(), ChipCssClassEffective)">
				@chipItem.ChipTemplate
				@if (chipItem.Removable)
				{
					<button type="button" class="chip-dismiss hx-chip-list-remove-btn" aria-label="@HxChipListLocalizer["Remove"]" @onclick="() => InvokeOnChipRemoveClickAsync(chipItem)" @onclick:stopPropagation>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="12" y2="12"/><line x1="12" y1="4" x2="4" y2="12"/></svg>
					</button>
				}
			</span>
		}
		@if (Chips.Any() && ShowResetButtonEffective)
		{
			@if (ResetButtonTemplate is not null)
			{
				@ResetButtonTemplate
			}
			else
			{
				<span role="button" class="hx-chip-list-reset-btn" @onclick="() => InvokeOnResetClickAsync()" @onclick:stopPropagation>
					@ResetButtonText
					<HxIcon Icon="BootstrapIcon.X" />
				</span>
			}
		}
	}
</div>
