@inherits LayoutComponentBase

<PageTitle>@_title</PageTitle>

<HxMessenger Position="ToastContainerPosition.MiddleCenter" />
<HxMessageBoxHost />

<Navbar />
<div class="doc-container container-fluid md:d-flex min-vh-100">
	<Sidebar CssClass="d-none lg:d-flex" />

	<div style="min-width: 0;" class="doc-content main md:p-4 pt-0 flex-grow-1 overflow-hidden">
        <CascadingValue Value="_docHeadContentTracker" IsFixed="true">
		    @Body
        </CascadingValue>
	</div>

	<OnThisPageNavigation CssClass="side-page-navigation sticky-top mt-4 d-none lg:d-block">
		<h6 class="mt-3 pb-1 border-bottom">On this page</h6>
	</OnThisPageNavigation>
</div>
