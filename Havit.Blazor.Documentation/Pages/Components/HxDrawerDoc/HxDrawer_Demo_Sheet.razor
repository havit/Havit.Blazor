<HxDrawer @ref="drawerComponent" Title="Title" Sheet="true">
	<BodyTemplate>
		<p>This drawer is rendered as a flush-to-edge sheet (no inset, border radius, or shadow).</p>
	</BodyTemplate>
</HxDrawer>

<HxButton OnClick="() => drawerComponent.ShowAsync()" Text="Show sheet drawer" Color="ThemeColor.Primary" />

@code
{
	private HxDrawer drawerComponent;
}
