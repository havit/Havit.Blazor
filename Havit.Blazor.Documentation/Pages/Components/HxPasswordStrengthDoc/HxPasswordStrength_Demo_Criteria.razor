@* Don't require uppercase letters, make special characters worth more points, adjust the thresholds for the new maximum score. *@
<HxPasswordStrength MinLength="12"
					Weights="new PasswordStrengthWeights { Uppercase = 0, Special = 2 }"
					Thresholds="new PasswordStrengthThresholds { Weak = 3, Fair = 5, Good = 7 }"
					ShowText="true">
	<HxInputText Label="Password (12+ characters recommended)" Type="InputType.Password" @bind-Value="password" BindEvent="BindEvent.OnInput" />
</HxPasswordStrength>

@code {
	private string password;
}
