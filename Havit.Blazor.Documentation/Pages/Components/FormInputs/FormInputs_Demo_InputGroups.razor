<HxInputText Label="Input groups (text)" @bind-Value="@value" InputGroupStartText="€" InputGroupEndText=".00" />
<HxInputText Label="Input groups (icon)" @bind-Value="@value">
	<InputGroupStartTemplate>
		<HxIcon CssClass="input-group-text" Icon="BootstrapIcon.CurrencyEuro" />
	</InputGroupStartTemplate>
</HxInputText>

<HxInputText Label="Input groups (template with button/menu)" @bind-Value="@value">
	<InputGroupStartTemplate>
		<HxButton Text="Button" Color="ThemeColor.Secondary" Variant="ButtonVariant.Outline" />
		<HxButton Text="Button 2" Color="ThemeColor.Secondary" Variant="ButtonVariant.Outline" />
	</InputGroupStartTemplate>
	<InputGroupEndTemplate>
		<HxMenu>
			<Toggle>
				<HxMenuToggleButton Text="Menu" Color="ThemeColor.Secondary" Variant="ButtonVariant.Outline" />
			</Toggle>
			<Content>
				<HxMenuItem>Item 1</HxMenuItem>
				<HxMenuItem>Item 2</HxMenuItem>
			</Content>
		</HxMenu>
	</InputGroupEndTemplate>
</HxInputText>

<HxInputText Label="Input groups (template with checkbox/radio)" @bind-Value="@value">
	<InputGroupStartTemplate>
		<div class="input-group-text">
			<HxCheckbox @bind-Value="@valueBool" CssClass="mt-0" />
		</div>
	</InputGroupStartTemplate>
</HxInputText>

@code
{
	private string value;
	private bool valueBool;
}
