<HxButton Color="ThemeColor.Primary"
		  Text="Toggle highlight"
		  data-bs-toggle="toggler"
		  data-bs-target="#toggler-demo-target" />

<div id="toggler-demo-target"
	 class="mt-3 p-3 border rounded"
	 data-bs-attribute="class"
	 data-bs-value="bg-subtle-warning">
	The <code>bg-subtle-warning</code> class gets toggled here — no C# state involved.
</div>
