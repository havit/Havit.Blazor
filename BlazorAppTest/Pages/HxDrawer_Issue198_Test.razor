@page "/HxDrawer_Issue198_Test"

<HxDrawer @ref="drawerComponent" CssClass="@(x ? "bg-success" : "bg-warning")">
	<BodyTemplate>
           <HxButton OnClick="() => x = !x" Text="Switch CSS" Color="ThemeColor.Primary" />
	</BodyTemplate>
</HxDrawer>

<HxButton OnClick="() => drawerComponent.ShowAsync()" Text="Open" Color="ThemeColor.Primary" />

@code
{
    private bool x;
    private HxDrawer drawerComponent;
}