{
    "name": "havit-bootstrap",
    "description": "The most popular front-end framework for developing responsive, mobile first projects on the web.",
    "version": "6.0.0-alpha1",
    "config": {
      "version_short": "6.0"
    },
    "keywords": [
      "css",
      "sass",
      "mobile-first",
      "responsive",
      "front-end",
      "framework",
      "web"
    ],
    "homepage": "https://getbootstrap.com/",
    "author": "The Bootstrap Authors (https://github.com/twbs/bootstrap/graphs/contributors)",
    "license": "MIT",
    "repository": {
      "type": "git",
      "url": "git+https://github.com/twbs/bootstrap.git"
    },
    "bugs": {
      "url": "https://github.com/twbs/bootstrap/issues"
    },
    "funding": [
      {
        "type": "github",
        "url": "https://github.com/sponsors/twbs"
      },
      {
        "type": "opencollective",
        "url": "https://opencollective.com/bootstrap"
      }
    ],
    "sass": "scss/bootstrap.scss",
    "style": "dist/css/bootstrap.css",
    "scripts": {
        "css": "npm-run-all css-clean css-compile css-prefix css-minify",
        "css-clean": "shx rm -rf dist/css",
        "css-compile": "sass --style expanded --source-map --embed-sources --no-error-css scss/:dist/css/",
        "css-lint": "npm-run-all --aggregate-output --continue-on-error --parallel css-lint-*",
        "css-lint-stylelint": "stylelint \"**/*.{css,scss}\" --cache --cache-location .cache/.stylelintcache",
        "css-minify": "node build/css-minify.mjs",
        "css-prefix": "postcss --config postcss.config.mjs --replace \"dist/css/*.css\" \"!dist/css/*.min.css\"",
        "watch": "npm-run-all --parallel watch-*",
        "watch-css-main": "nodemon --watch scss/ --ext scss --exec \"npm-run-all css-compile css-prefix\"",
        "publish-to-blazor": "shx cp -r dist/css/* node_modules/bootstrap/dist/js/bootstrap.bundle.min.js node_modules/bootstrap/dist/js/bootstrap.bundle.min.js.map ../Havit.Blazor.Components.Web.Bootstrap/wwwroot"
    },
    "devDependencies": {
      "autoprefixer": "^10.4.21",
      "bootstrap": "github:twbs/bootstrap#82b040e9f74c79430093a3cf46bd691825e7c10d",
      "browserslist": "^4.24.4",
      "lightningcss": "^1.32.0",
      "nodemon": "^3.1.10",
      "npm-run-all2": "^8.0.4",
      "postcss": "^8.5.6",
      "postcss-cli": "^11.0.1",
      "postcss-prefix-custom-properties": "^0.1.0",
      "sass": "^1.100.0",
      "stylelint": "^16.23.1",
      "stylelint-config-twbs-bootstrap": "^16.1.0",
      "shx":"^0.4.0"
  },
    "files": [
        "dist/{css}/*.{css,map}",
        "scss/**/*.scss"
    ]
}
