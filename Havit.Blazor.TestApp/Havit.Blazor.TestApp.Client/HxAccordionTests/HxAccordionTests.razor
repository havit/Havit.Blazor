@page "/HxAccordionTests"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<h3 data-testid="page-title">HxAccordion Tests</h3>

<div data-testid="accordion-default">
	<HxAccordion>
		<HxAccordionItem Id="item1">
			<HeaderTemplate><span data-testid="header-1">Item 1</span></HeaderTemplate>
			<BodyTemplate><span data-testid="body-1">Content 1</span></BodyTemplate>
		</HxAccordionItem>
		<HxAccordionItem Id="item2">
			<HeaderTemplate><span data-testid="header-2">Item 2</span></HeaderTemplate>
			<BodyTemplate><span data-testid="body-2">Content 2</span></BodyTemplate>
		</HxAccordionItem>
		<HxAccordionItem Id="item3">
			<HeaderTemplate><span data-testid="header-3">Item 3</span></HeaderTemplate>
			<BodyTemplate><span data-testid="body-3">Content 3</span></BodyTemplate>
		</HxAccordionItem>
	</HxAccordion>
</div>

<div data-testid="accordion-stayopen">
	<HxAccordion StayOpen="true">
		<HxAccordionItem Id="stayopen-item1">
			<HeaderTemplate><span data-testid="stayopen-header-1">StayOpen Item 1</span></HeaderTemplate>
			<BodyTemplate><span data-testid="stayopen-body-1">StayOpen Content 1</span></BodyTemplate>
		</HxAccordionItem>
		<HxAccordionItem Id="stayopen-item2">
			<HeaderTemplate><span data-testid="stayopen-header-2">StayOpen Item 2</span></HeaderTemplate>
			<BodyTemplate><span data-testid="stayopen-body-2">StayOpen Content 2</span></BodyTemplate>
		</HxAccordionItem>
	</HxAccordion>
</div>
