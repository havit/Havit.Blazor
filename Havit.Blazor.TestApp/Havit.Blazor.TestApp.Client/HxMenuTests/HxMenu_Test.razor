@page "/HxMenu"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<HxMenu>
	<Toggle>
		<HxMenuToggleButton data-testid="toggle-button" Color="ThemeColor.Primary">Open Menu</HxMenuToggleButton>
	</Toggle>
	<Content>
		<HxMenuHeader>Section Header</HxMenuHeader>
		<HxMenuItem data-testid="action-item" OnClick="HandleItemClick">Action Item</HxMenuItem>
		<HxMenuDivider />
		<HxMenuItem>Another Item</HxMenuItem>
	</Content>
</HxMenu>

<p data-testid="item-click-count">@_itemClickCount</p>

<p data-testid="outside-click-area" style="margin-top: 200px;">Outside click area</p>

@code {
	private int _itemClickCount;

	private void HandleItemClick()
	{
		_itemClickCount++;
	}
}
