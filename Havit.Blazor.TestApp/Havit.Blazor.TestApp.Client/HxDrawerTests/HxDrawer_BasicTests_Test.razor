@page "/HxDrawer_BasicTests"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<HxButton data-testid="show-button" OnClick="HandleShowClick" Color="ThemeColor.Primary">Show Drawer</HxButton>

<HxDrawer @ref="_drawer" Title="Test Drawer">
	<BodyTemplate>
		<p data-testid="drawer-content">Drawer body content</p>
	</BodyTemplate>
</HxDrawer>

@code {
	private HxDrawer _drawer;

	private async Task HandleShowClick()
	{
		await _drawer.ShowAsync();
	}
}
